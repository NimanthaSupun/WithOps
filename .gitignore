# ===================================
# WithOps DevSecOps Platform
# Root .gitignore
# ===================================

# Environment Variables & Secrets
.env
.env.*
!.env.example
!.env.test
*.pem
*.key
*.cert
*.p12
*.pfx

# Databases
*.db
*.sqlite
*.sqlite3
devsecops.db
*.db-shm
*.db-wal

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Note: Only ignore Python's lib, not frontend/src/lib
backend/lib/
services/*/lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
venv/
.venv/
ENV/
env/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
devsecops-backend.log*

# OS
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Uploads & User Content
uploads/
uploads/*
!uploads/.gitkeep
documents/
temp/
tmp/

# Cache
.cache/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
__pycache__/

# Docker
.dockerignore
docker-compose.override.yml

# Build outputs
dist/
build/
*.egg-info/
.svelte-kit/
.output/
.vercel/
.netlify/
.wrangler/

# Testing
.coverage
htmlcov/
.pytest_cache/
coverage/

# ML Models & Data
*.pkl
*.h5
*.model
*.joblib
ml_scanner/models/*.pkl
ml_scanner/data/*.csv
ml_scanner/data/*.json
!ml_scanner/data/.gitkeep

# Sensitive Analysis Files
analysis_data.json
structured_analysis.json

# Redis
dump.rdb

# Temporary files
*.tmp
*.bak
*.swp
*.swo
*~

# Security scanner results
.semgrep/
.bandit/
trivy-results.json
