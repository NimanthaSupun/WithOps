
# Supabase Project Settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection (PostgreSQL)
# Get this from Supabase Settings > Database > Connection String
SUPABASE_DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Security
DATABASE_ENCRYPTION_KEY=your-32-character-encryption-key-here

# GitHub App Configuration (existing)
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY_PATH=./github-app-private-key.pem
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_APP_NAME=your-github-app-name

# Optional: Personal Access Token for fetching real-time action versions
GITHUB_TOKEN=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

# Auth0 Configuration (existing)
AUTH0_DOMAIN=your-auth0-domain
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=your-auth0-api-audience

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
