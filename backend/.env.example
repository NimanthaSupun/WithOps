# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ===================================
# Supabase Project Settings
# ===================================
SUPABASE_URL=https://your-project-id-here.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ===================================
# Database Connection (PostgreSQL)
# ===================================
# For local development (uncomment to use SQLite)
# LOCAL_DATABASE_URL=sqlite+aiosqlite:///./devsecops.db

# For production/Supabase cloud - Using Session Pooler (IPv4 compatible)
SUPABASE_DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# ===================================
# Security
# ===================================
# Generate a secure key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATABASE_ENCRYPTION_KEY=your-encryption-key-here

# ===================================
# GitHub OAuth Configuration
# ===================================
# Create at: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret

# ===================================
# GitHub App Configuration
# ===================================
# Create at: https://github.com/settings/apps
GITHUB_APP_ID=your-app-id
GITHUB_APP_CLIENT_ID=your-app-client-id
GITHUB_APP_CLIENT_SECRET=your-app-client-secret
GITHUB_APP_NAME=your-app-name
GITHUB_PRIVATE_KEY_PATH=./github-app-private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ===================================
# GitHub Personal Access Token
# ===================================
# Create at: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:org
GITHUB_TOKEN=your-github-personal-access-token-here

# ===================================
# Auth0 Configuration
# ===================================
# Create at: https://auth0.com/
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_API_AUDIENCE=https://api.yourdomain.com

# ===================================
# JWT Configuration
# ===================================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your-super-secret-jwt-key-at-least-32-characters-long

# ===================================
# Application Settings
# ===================================
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Test Mode (disable for production)
# TEST_MODE=true

# ===================================
# Redis Configuration
# ===================================
REDIS_URL=redis://localhost:6379

# ===================================
# Ollama Configuration (Local AI)
# ===================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
# Alternative models: codellama, mistral, phi, gemma

# ===================================
# Groq AI Configuration
# ===================================
# Get API key at: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# ===================================
# Anthropic Claude API Configuration
# ===================================
# Get API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here