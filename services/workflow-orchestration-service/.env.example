# Workflow Orchestration Service Configuration

# Service Configuration
SERVICE_NAME=workflow-orchestration-service
SERVICE_PORT=8007
SERVICE_VERSION=1.0.0
ENVIRONMENT=development

# Database Configuration (Supabase)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Microservices URLs
GITHUB_SERVICE_URL=http://github-service:8002
AUTH_SERVICE_URL=http://auth-service:8001
AI_SERVICE_URL=http://ai-service:8001

# GitHub Configuration (for direct API calls if needed)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_PRIVATE_KEY_PATH=

# Security Scanning
ENABLE_SECURITY_SCANNING=true
SECURITY_SCAN_TIMEOUT=300

# Real-time Features
ENABLE_SSE=true
ENABLE_WEBSOCKET=true
SSE_HEARTBEAT_INTERVAL=30

# Monitoring and Tracing
ENABLE_METRICS=true
ENABLE_TRACING=true
OTLP_ENDPOINT=http://jaeger:4318/v1/traces

# Caching
CACHE_TTL=3600
ENABLE_CACHE=true

# Workflow Execution
MAX_CONCURRENT_EXECUTIONS=10
EXECUTION_TIMEOUT=1800

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
