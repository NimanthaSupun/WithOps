# Environment variables for AI RAG Service

# ============================================
# AUTH0 CONFIGURATION (REQUIRED FOR MULTI-USER SUPPORT)
# ============================================
# Auth0 domain (e.g., your-tenant.us.auth0.com)
AUTH0_DOMAIN=your-tenant.auth0.com

# Auth0 API Identifier/Audience (from your API settings in Auth0 dashboard)
AUTH0_AUDIENCE=https://your-api-identifier

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_HOST=http://ollama:11434

# ============================================
# QDRANT CONFIGURATION
# ============================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ============================================
# ANTHROPIC API
# ============================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://redis:6379

# Redis conversation settings
CONVERSATION_TTL_HOURS=24
MAX_CONVERSATION_LENGTH=20

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://postgres.fcmcsbmsntmpeyjltqbi:5m19NTF6y0x1fJgr@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ============================================
# SERVICE CONFIGURATION
# ============================================
LOG_LEVEL=INFO
MAX_EMBEDDING_BATCH_SIZE=10
VECTOR_SEARCH_LIMIT=5

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_CACHING=true
ENABLE_METRICS=true
