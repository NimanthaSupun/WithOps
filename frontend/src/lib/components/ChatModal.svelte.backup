<script>
	import { createEventDispatcher } from 'svelte';
	import { page } from '$app/stores';
	import { ragAPI } from '$lib/api/rag';
	
	export let isOpen = false;
	export let orgName = '';
	export let repoName = null;
	export let projectName = null;
	export let folderPath = null;
	export let analysisScope = 'unified';
	export let analysisId = null;  // NEW - specific analysis to query
	
	const dispatch = createEventDispatcher();
	
	let question = '';
	let messages = [];
	let isLoading = false;
	let conversationId = null;
	let errorMessage = '';
	let authToken = null;
	
	// Get auth token when modal opens
	$: if (isOpen) {
		authToken = $page.data.user?.accessToken || localStorage.getItem('auth_token');
		if (!authToken) {
			errorMessage = 'Please log in to use the AI Assistant';
		}
	}
	
	// Suggested questions
	const suggestedQuestions = [
		"What security practices are implemented in our workflows?",
		"What are the main security findings from the analysis?",
		"How can we improve our DevSecOps maturity score?",
		"What SAST tools are being used?",
		"Are there any security vulnerabilities in our CI/CD pipeline?",
		"What's our current security scanning coverage?"
	];
	
	async function sendMessage() {
		if (!question.trim() || isLoading) return;
		
		if (!authToken) {
			errorMessage = 'Please log in to use the AI Assistant';
			return;
		}
		
		const userMessage = question.trim();
		question = '';
		errorMessage = '';
		
		// Add user message to UI
		messages = [...messages, {
			role: 'user',
			content: userMessage,
			timestamp: new Date()
		}];
		
		isLoading = true;
		
		try {
			const response = await ragAPI.chat({
				question: userMessage,
				org_name: orgName,
				repo_name: repoName,
				project_name: projectName,
				folder_path: folderPath,
				analysis_scope: analysisScope,
				analysis_id: analysisId,  // Include analysis_id for historical queries
				conversation_id: conversationId,
				token: authToken
			});
			
			// Store conversation ID for follow-up questions
			if (!conversationId) {
				conversationId = response.conversation_id;
			}
			
			// Add AI response to UI
			messages = [...messages, {
				role: 'assistant',
				content: response.answer,
				sources: response.sources,
				confidence: response.confidence,
				contexts_used: response.contexts_used,
				timestamp: new Date()
			}];
			
		} catch (error) {
			console.error('Chat error:', error);
			errorMessage = error.message || 'Failed to get response. Please try again.';
			
			// If authentication error, remove token and prompt re-login
			if (error.message.includes('Authentication')) {
				localStorage.removeItem('auth_token');
				authToken = null;
			}
		} finally {
			isLoading = false;
		}
	}
	
	function useSuggestedQuestion(suggested) {
		question = suggested;
		sendMessage();
	}
	
	function closeModal() {
		dispatch('close');
	}
	
	function clearConversation() {
		messages = [];
		conversationId = null;
		errorMessage = '';
		question = '';
	}
	
	function handleKeyPress(event) {
		if (event.key === 'Enter' && !event.shiftKey) {
			event.preventDefault();
			sendMessage();
		}
	}
</script>

{#if isOpen}
	<div class="modal-backdrop" on:click={closeModal} on:keydown={(e) => e.key === 'Escape' && closeModal()} role="button" tabindex="0">
		<div class="chat-modal" on:click|stopPropagation on:keydown|stopPropagation role="dialog" tabindex="-1">
			<!-- Header -->
			<div class="modal-header">
				<div class="header-content">
					<h2>🤖 Ask AI Assistant</h2>
					<p class="context-info">
						{#if orgName}
							<span class="badge">{orgName}</span>
						{/if}
						{#if repoName}
							<span class="badge">{repoName}</span>
						{/if}
					</p>
				</div>
				<div class="header-actions">
					{#if messages.length > 0}
						<button class="btn-icon" on:click={clearConversation} title="Clear conversation">
							🗑️
						</button>
					{/if}
					<button class="btn-icon" on:click={closeModal} title="Close">
						✕
					</button>
				</div>
			</div>
			
			<!-- Messages Area -->
			<div class="messages-container">
				{#if messages.length === 0}
					<div class="empty-state">
						<div class="welcome">
							<h3>👋 Hello! I'm your DevSecOps AI Assistant</h3>
							<p>I can help you understand your security analysis, workflows, and DevSecOps practices.</p>
						</div>
						
						<div class="suggested-questions">
							<p class="label">Try asking:</p>
							<div class="suggestions-grid">
								{#each suggestedQuestions as suggested}
									<button 
										class="suggestion-chip" 
										on:click={() => useSuggestedQuestion(suggested)}
									>
										{suggested}
									</button>
								{/each}
							</div>
						</div>
					</div>
				{:else}
					<div class="messages-list">
						{#each messages as message}
							<div class="message {message.role}">
								<div class="message-header">
									<span class="role-badge">
										{message.role === 'user' ? '👤 You' : '🤖 AI Assistant'}
									</span>
									<span class="timestamp">
										{message.timestamp.toLocaleTimeString()}
									</span>
								</div>
								
								<div class="message-content">
									{message.content}
								</div>
								
								{#if message.role === 'assistant'}
									<div class="message-footer">
										{#if message.confidence}
											<span class="confidence confidence-{message.confidence}">
												Confidence: {message.confidence}
											</span>
										{/if}
										{#if message.contexts_used}
											<span class="contexts">
												📄 {message.contexts_used} sources
											</span>
										{/if}
										
										{#if message.sources && message.sources.length > 0}
											<details class="sources">
												<summary>View sources ({message.sources.length})</summary>
												<ul>
													{#each message.sources as source}
														<li>
															{#if source.type === 'workflow'}
																<strong>Workflow:</strong> {source.repo}/{source.file}
																<span class="relevance">(relevance: {source.relevance})</span>
															{:else if source.type === 'analysis'}
																<strong>Analysis:</strong> {source.organization} - {source.analysis_type}
																<span class="relevance">(relevance: {source.relevance})</span>
															{/if}
														</li>
													{/each}
												</ul>
											</details>
										{/if}
									</div>
								{/if}
							</div>
						{/each}
						
						{#if isLoading}
							<div class="message assistant loading">
								<div class="message-header">
									<span class="role-badge">🤖 AI Assistant</span>
								</div>
								<div class="loading-indicator">
									<span class="dot"></span>
									<span class="dot"></span>
									<span class="dot"></span>
								</div>
							</div>
						{/if}
					</div>
				{/if}
			</div>
			
			<!-- Error Display -->
			{#if errorMessage}
				<div class="error-banner">
					⚠️ {errorMessage}
				</div>
			{/if}
			
			<!-- Input Area -->
			<div class="input-area">
				<textarea
					bind:value={question}
					on:keypress={handleKeyPress}
					placeholder="Ask a question about your security analysis..."
					disabled={isLoading}
					rows="3"
				></textarea>
				<button 
					class="btn-send" 
					on:click={sendMessage}
					disabled={!question.trim() || isLoading}
				>
					{isLoading ? '⏳' : '📤'} Send
				</button>
			</div>
		</div>
	</div>
{/if}

<style>
	.modal-backdrop {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(4px);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 9999;
		padding: 20px;
	}
	
	.chat-modal {
		background: white;
		border-radius: 16px;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
		width: 100%;
		max-width: 800px;
		height: 85vh;
		max-height: 700px;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}
	
	.modal-header {
		padding: 20px 24px;
		border-bottom: 1px solid #e5e7eb;
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
	}
	
	.header-content h2 {
		margin: 0 0 8px 0;
		font-size: 24px;
		font-weight: 600;
	}
	
	.context-info {
		margin: 0;
		display: flex;
		gap: 8px;
		font-size: 14px;
		opacity: 0.9;
	}
	
	.badge {
		background: rgba(255, 255, 255, 0.2);
		padding: 4px 12px;
		border-radius: 12px;
		font-size: 13px;
	}
	
	.header-actions {
		display: flex;
		gap: 8px;
	}
	
	.btn-icon {
		background: rgba(255, 255, 255, 0.2);
		border: none;
		color: white;
		width: 36px;
		height: 36px;
		border-radius: 50%;
		cursor: pointer;
		font-size: 18px;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.2s;
	}
	
	.btn-icon:hover {
		background: rgba(255, 255, 255, 0.3);
	}
	
	.messages-container {
		flex: 1;
		overflow-y: auto;
		padding: 24px;
		background: #f9fafb;
	}
	
	.empty-state {
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 32px;
	}
	
	.welcome {
		text-align: center;
	}
	
	.welcome h3 {
		font-size: 24px;
		margin: 0 0 12px 0;
		color: #1f2937;
	}
	
	.welcome p {
		color: #6b7280;
		margin: 0;
	}
	
	.suggested-questions {
		max-width: 600px;
		margin: 0 auto;
	}
	
	.label {
		font-weight: 500;
		color: #6b7280;
		margin-bottom: 12px;
	}
	
	.suggestions-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 12px;
	}
	
	.suggestion-chip {
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 8px;
		padding: 12px 16px;
		text-align: left;
		cursor: pointer;
		transition: all 0.2s;
		font-size: 14px;
		color: #374151;
	}
	
	.suggestion-chip:hover {
		border-color: #667eea;
		background: #f0f4ff;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
	}
	
	.messages-list {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}
	
	.message {
		background: white;
		border-radius: 12px;
		padding: 16px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
	}
	
	.message.user {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		margin-left: 48px;
	}
	
	.message.assistant {
		margin-right: 48px;
	}
	
	.message-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 8px;
	}
	
	.role-badge {
		font-weight: 600;
		font-size: 13px;
	}
	
	.message.user .role-badge {
		color: rgba(255, 255, 255, 0.9);
	}
	
	.timestamp {
		font-size: 12px;
		opacity: 0.6;
	}
	
	.message-content {
		line-height: 1.6;
		white-space: pre-wrap;
	}
	
	.message-footer {
		margin-top: 12px;
		padding-top: 12px;
		border-top: 1px solid #e5e7eb;
		display: flex;
		gap: 16px;
		align-items: center;
		flex-wrap: wrap;
		font-size: 13px;
	}
	
	.confidence {
		padding: 4px 8px;
		border-radius: 4px;
		font-weight: 500;
	}
	
	.confidence-high {
		background: #d1fae5;
		color: #065f46;
	}
	
	.confidence-medium {
		background: #fef3c7;
		color: #92400e;
	}
	
	.confidence-low {
		background: #fee2e2;
		color: #991b1b;
	}
	
	.contexts {
		color: #6b7280;
	}
	
	.sources {
		width: 100%;
	}
	
	.sources summary {
		cursor: pointer;
		color: #667eea;
		font-weight: 500;
	}
	
	.sources ul {
		margin: 8px 0 0 0;
		padding-left: 20px;
	}
	
	.sources li {
		margin: 4px 0;
		font-size: 12px;
		color: #6b7280;
	}
	
	.relevance {
		color: #9ca3af;
		font-size: 11px;
	}
	
	.loading-indicator {
		display: flex;
		gap: 8px;
		padding: 8px 0;
	}
	
	.dot {
		width: 8px;
		height: 8px;
		background: #667eea;
		border-radius: 50%;
		animation: bounce 1.4s infinite ease-in-out both;
	}
	
	.dot:nth-child(1) { animation-delay: -0.32s; }
	.dot:nth-child(2) { animation-delay: -0.16s; }
	
	@keyframes bounce {
		0%, 80%, 100% { transform: scale(0); }
		40% { transform: scale(1); }
	}
	
	.error-banner {
		background: #fee2e2;
		color: #991b1b;
		padding: 12px 24px;
		border-top: 1px solid #fecaca;
	}
	
	.input-area {
		padding: 20px 24px;
		border-top: 1px solid #e5e7eb;
		background: white;
		display: flex;
		gap: 12px;
	}
	
	textarea {
		flex: 1;
		border: 2px solid #e5e7eb;
		border-radius: 8px;
		padding: 12px;
		font-family: inherit;
		font-size: 14px;
		resize: none;
		transition: border-color 0.2s;
	}
	
	textarea:focus {
		outline: none;
		border-color: #667eea;
	}
	
	textarea:disabled {
		background: #f9fafb;
		cursor: not-allowed;
	}
	
	.btn-send {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		border: none;
		border-radius: 8px;
		padding: 12px 24px;
		font-weight: 600;
		cursor: pointer;
		transition: transform 0.2s, box-shadow 0.2s;
		white-space: nowrap;
	}
	
	.btn-send:hover:not(:disabled) {
		transform: translateY(-2px);
		box-shadow: 0 8px 16px rgba(102, 126, 234, 0.3);
	}
	
	.btn-send:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}
</style>
