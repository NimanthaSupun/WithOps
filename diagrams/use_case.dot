digraph UseCaseDiagram {
    rankdir=LR;
    graph [fontname="Segoe UI, Arial", bgcolor="white", pad="0.6,0.4",
           nodesep=0.6, ranksep=1.8, dpi=120,
           label=<<B>Figure 5.1 — WithOps Use Case Diagram</B>>,
           labelloc=t, fontsize=16, fontcolor="#0f172a"];
    node [fontname="Segoe UI, Arial", fontsize=10];
    edge [fontname="Segoe UI, Arial", fontsize=8, color="#94a3b8", arrowhead=none, penwidth=1.2];

    // ======= ACTORS (SVG stick figures) =======
    Developer [shape=none, label=<
        <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="0">
        <TR><TD><IMG SRC="actor.png"/></TD></TR>
        <TR><TD><FONT POINT-SIZE="11"><B>Developer</B></FONT></TD></TR>
        </TABLE>
    >];

    SecurityEngineer [shape=none, label=<
        <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="0">
        <TR><TD><IMG SRC="actor.png"/></TD></TR>
        <TR><TD><FONT POINT-SIZE="11"><B>Security</B></FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="11"><B>Engineer</B></FONT></TD></TR>
        </TABLE>
    >];

    DevOpsEngineer [shape=none, label=<
        <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="0">
        <TR><TD><IMG SRC="actor.png"/></TD></TR>
        <TR><TD><FONT POINT-SIZE="11"><B>DevOps</B></FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="11"><B>Engineer</B></FONT></TD></TR>
        </TABLE>
    >];

    EngineeringManager [shape=none, label=<
        <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="0">
        <TR><TD><IMG SRC="actor.png"/></TD></TR>
        <TR><TD><FONT POINT-SIZE="11"><B>Engineering</B></FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="11"><B>Manager</B></FONT></TD></TR>
        </TABLE>
    >];

    // ======= ORDERING: Actors on the left =======
    {rank=same; Developer; SecurityEngineer;}
    {rank=same; DevOpsEngineer; EngineeringManager;}

    // ======= SYSTEM BOUNDARY =======
    subgraph cluster_system {
        label=<<B>   WithOps DevSecOps Intelligence Platform   </B>>;
        labeljust=c; fontsize=13; fontcolor="#1e40af";
        fontname="Segoe UI, Arial";
        style="rounded,bold"; color="#3b82f6"; penwidth=2;
        bgcolor="#f8fafc";
        margin=20;

        // --- Authentication & Access ---
        UC01 [shape=ellipse, style="filled,bold", fillcolor="#dbeafe", color="#3b82f6",
              fontcolor="#1e3a5f", label="UC01\nAuthenticate\nvia Auth0", width=1.8, height=0.8];

        // --- GitHub Integration ---
        UC02 [shape=ellipse, style="filled,bold", fillcolor="#d1fae5", color="#059669",
              fontcolor="#064e3b", label="UC02\nConnect GitHub\nOrganisation", width=1.8, height=0.8];

        // --- Security Scanning ---
        UC03 [shape=ellipse, style="filled,bold", fillcolor="#fef3c7", color="#d97706",
              fontcolor="#78350f", label="UC03\nRun Security\nScan", width=1.8, height=0.8];

        // --- Workspace Intelligence ---
        UC04 [shape=ellipse, style="filled,bold", fillcolor="#ede9fe", color="#7c3aed",
              fontcolor="#3b0764", label="UC04\nView Workspace\nIntelligence", width=1.8, height=0.8];

        // --- DSOMM Maturity ---
        UC05 [shape=ellipse, style="filled,bold", fillcolor="#fef3c7", color="#d97706",
              fontcolor="#78350f", label="UC05\nAssess DSOMM\nMaturity", width=1.8, height=0.8];

        // --- Threat Modeling ---
        UC06 [shape=ellipse, style="filled,bold", fillcolor="#dcfce7", color="#16a34a",
              fontcolor="#14532d", label="UC06\nCreate Threat\nModel", width=1.8, height=0.8];

        // --- AI Threat Analysis ---
        UC08 [shape=ellipse, style="filled,bold", fillcolor="#dcfce7", color="#16a34a",
              fontcolor="#14532d", label="UC08\nAI Threat\nAnalysis", width=1.8, height=0.8];

        // --- AI RAG Chat ---
        UC09 [shape=ellipse, style="filled,bold", fillcolor="#f3e8ff", color="#9333ea",
              fontcolor="#581c87", label="UC09\nChat with\nAI RAG", width=1.8, height=0.8];

        // --- Action Audit ---
        UC10 [shape=ellipse, style="filled,bold", fillcolor="#fef3c7", color="#d97706",
              fontcolor="#78350f", label="UC10\nAudit GitHub\nActions", width=1.8, height=0.8];

        // --- Auto Remediation ---
        UC11 [shape=ellipse, style="filled,bold", fillcolor="#fef3c7", color="#d97706",
              fontcolor="#78350f", label="UC11\nAuto-Remediate\nvia PR", width=1.8, height=0.8];

        // --- Canvas / Pipeline Builder ---
        UC12 [shape=ellipse, style="filled,bold", fillcolor="#f3e8ff", color="#9333ea",
              fontcolor="#581c87", label="UC12\nBuild CI/CD\nPipeline", width=1.8, height=0.8];
    }

    // ======= ACTOR → USE CASE CONNECTIONS =======

    // Developer (left side)
    Developer -> UC01 [label="  "];
    Developer -> UC02;
    Developer -> UC03;
    Developer -> UC06;
    Developer -> UC09;

    // Security Engineer (left side)
    SecurityEngineer -> UC03;
    SecurityEngineer -> UC05;
    SecurityEngineer -> UC06;
    SecurityEngineer -> UC08;
    SecurityEngineer -> UC10;

    // DevOps Engineer (right side)
    UC02 -> DevOpsEngineer;
    UC10 -> DevOpsEngineer;
    UC11 -> DevOpsEngineer;
    UC12 -> DevOpsEngineer;

    // Engineering Manager (right side)
    UC04 -> EngineeringManager;
    UC05 -> EngineeringManager;
    UC08 -> EngineeringManager;
}
