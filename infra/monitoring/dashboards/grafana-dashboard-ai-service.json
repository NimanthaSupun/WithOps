                                                                           "fillOpacity":  10
                                                                       }
                                                        }
                                       }
                   },
                   {
                       "id":  12,
                       "gridPos":  {
                                       "h":  8,
                                       "w":  24,
                                       "x":  0,
                                       "y":  30
                                   },
                       "type":  "table",
                       "title":  "Endpoint Performance Summary",
                       "targets":  [
                                       {
                                           "expr":  "sum by (endpoint, method, status) (http_requests_total{job=\"ai-service\"})",
                                           "format":  "table",
                                           "instant":  true,
                                           "refId":  "A"
                                       }
                                   ],
                       "transformations":  [
                                               {
                                                   "id":  "organize",
                                                   "options":  {
                                                                   "excludeByName":  {
                                                                                         "Time":  true,
                                                                                         "job":  true,
                                                                                         "__name__":  true
                                                                                     },
                                                                   "renameByName":  {
                                                                                        "endpoint":  "Endpoint",
                                                                                        "method":  "Method",
                                                                                        "status":  "Status",
                                                                                        "Value":  "Total Requests"
                                                                                    }
                                                               }
                                               }
                                           ]
                   }
               ]
}
