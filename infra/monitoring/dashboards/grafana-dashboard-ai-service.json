                       "type":  "stat",
                       "title":  "Python Version",
                       "targets":  [
                                       {
                                           "expr":  "python_info{job=\"ai-service\"}",
                                           "refId":  "A"
                                       }
                                   ],
                       "options":  {
                                       "textMode":  "name"
                                   },
                       "transformations":  [
                                               {
                                                   "id":  "labelsToFields",
                                                   "options":  {

                                                               }
                                               }
                                           ]
                   },
                   {
                       "id":  10,
                       "gridPos":  {
                                       "h":  8,
                                       "w":  12,
                                       "x":  0,
                                       "y":  22
                                   },
                       "type":  "timeseries",
                       "title":  "HTTP Status Codes",
                       "targets":  [
                                       {
                                           "expr":  "sum by (status) (rate(http_requests_total{job=\"ai-service\"}[1m]))",
                                           "legendFormat":  "{{status}}",
                                           "refId":  "A"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "color":  {
                                                                          "mode":  "palette-classic"
                                                                      },
                                                            "custom":  {
                                                                           "drawStyle":  "bars",
                                                                           "fillOpacity":  100,
                                                                           "axisLabel":  "req/s"
                                                                       }
                                                        }
                                       }
                   },
                   {
                       "id":  11,
                       "gridPos":  {
                                       "h":  8,
                                       "w":  12,
                                       "x":  12,
                                       "y":  22
                                   },
                       "type":  "timeseries",
                       "title":  "Garbage Collection Events",
                       "targets":  [
                                       {
                                           "expr":  "rate(python_gc_collections_total{job=\"ai-service\"}[1m])",
                                           "legendFormat":  "Gen {{generation}}",
                                           "refId":  "A"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "color":  {
