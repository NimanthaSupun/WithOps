{
  "title": "WithOps Collaboration Service Monitoring",
  "tags": ["collaboration", "microservices", "withops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"collaboration-service\"}[1m])",
          "legendFormat": "{{method}} {{endpoint}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "requests/sec",
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "type": "timeseries",
      "title": "Request Duration (95th percentile)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"collaboration-service\"}[5m]))",
          "legendFormat": "{{endpoint}} (p95)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "s"
        }
      }
    },
    {
      "id": 3,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "type": "stat",
      "title": "Total Requests",
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"collaboration-service\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "type": "stat",
      "title": "Error Rate (%)",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"collaboration-service\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"collaboration-service\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "id": 5,
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "type": "stat",
      "title": "Memory Usage",
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"collaboration-service\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 300000000, "color": "yellow" },
              { "value": 500000000, "color": "red" }
            ]
          },
          "unit": "bytes"
        }
      }
    },
    {
      "id": 6,
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "type": "stat",
      "title": "Service Uptime",
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"collaboration-service\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s"
        }
      }
    },
    {
      "id": 7,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "type": "timeseries",
      "title": "Collaboration Endpoints Activity",
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(http_requests_total{job=\"collaboration-service\"}[5m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      }
    }
  ]
}
